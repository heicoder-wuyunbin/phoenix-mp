<view class="container">
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:else class="goods-detail">
    <swiper class="goods-swiper" indicator-dots autoplay circular>
      <swiper-item wx:if="{{goodsInfo.images && goodsInfo.images.length > 0}}">
        <image wx:for="{{goodsInfo.images}}" wx:key="index" src="{{item}}" mode="aspectFill" class="goods-image"/>
      </swiper-item>
      <swiper-item wx:else>
        <image src="{{goodsInfo.image}}" mode="aspectFill" class="goods-image"/>
      </swiper-item>
    </swiper>

    <view class="goods-info">
      <text class="goods-name">{{goodsInfo.name}}</text>
      <view class="price-row">
        <text class="goods-price">¥{{currentPrice}}</text>
        <text class="goods-sales">销量 {{goodsInfo.sales}}</text>
      </view>
      <text class="goods-category">分类：{{goodsInfo.categoryName}}</text>
      <text class="goods-stock">库存：{{currentStock}} 件</text>
    </view>

    <view class="spec-section" wx:if="{{specTree.length > 0}}">
      <text class="section-title">规格选择</text>
      <view class="spec-list">
        <view class="spec-item" wx:for="{{specTree}}" wx:key="name">
          <text class="spec-name">{{item.name}}</text>
          <view class="spec-options">
            <view
              class="spec-option {{selectedSpec[item.name] === option ? 'selected' : ''}}"
              wx:for="{{item.options}}"
              wx:key="option"
              wx:for-item="option"
              bindtap="onSpecSelect"
              data-spec="{{item.name}}"
              data-option="{{option}}"
            >
              {{option}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="goods-desc" wx:if="{{goodsInfo.description}}">
      <text class="section-title">商品描述</text>
      <text class="desc-content">{{goodsInfo.description}}</text>
    </view>

    <view class="goods-desc" wx:if="{{goodsInfo.content}}">
      <text class="section-title">商品详情</text>
      <rich-text class="desc-content" nodes="{{goodsInfo.content}}"></rich-text>
    </view>
  </view>

  <view class="footer">
    <view class="footer-left">
      <view class="footer-item" bindtap="goToCart">
        <icon type="cart" size="24" />
        <text>购物车</text>
      </view>
      <view class="footer-item" bindtap="goToHome">
        <icon type="home" size="24" />
        <text>首页</text>
      </view>
    </view>
    <view class="footer-right">
      <button class="btn-cart" bindtap="addToCart">加入购物车</button>
      <button class="btn-buy" bindtap="buyNow">立即购买</button>
    </view>
  </view>
</view>
